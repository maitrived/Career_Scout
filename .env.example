# Gemini API credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Database configurations (Uses local SQLite by default)
# Database file is stored at data/auto_applier.db

# Apify API token (for scraping LinkedIn/Indeed fallbacks)
APIFY_API_TOKEN=your_apify_api_token_here
SCRAPPER=curious_coder/linkedin-jobs-scraper


# NVIDIA NIM API key (optional, for fast LLM inference)
NVIDIA_NIM_API_KEY=your_nim_api_key_here
LLM_MODEL=meta/llama-3.3-70b-instruct
# TS Playwright PDF service port
PDF_SERVICE_PORT=3001

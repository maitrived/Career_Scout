<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <style>
        :root {
            --font-size: 10pt;
            --line-height: 1.20;
            --section-gap: 8px;
            --bullet-gap: 1px;
            --margin-top: 4px;
        }

        body {
            font-family: 'Latin Modern Roman', 'Computer Modern Roman', 'Times New Roman', Georgia, serif;
            font-size: var(--font-size);
            line-height: var(--line-height);
            color: #000;
            margin: 0;
            padding: 0;
        }

        h1 {
            text-align: center;
            font-size: 18pt;
            margin: 0 0 4px 0;
            font-weight: bold;
            line-height: 1.15;
        }

        p:nth-of-type(1) {
            text-align: center;
            margin: 0 0 6px 0;
            font-size: 12pt;
            line-height: 1.15;
        }

        a {
            color: #000;
            text-decoration: none;
        }

        h2 {
            font-size: 11pt;
            text-transform: uppercase;
            border-bottom: 1px solid #000;
            margin: calc(var(--section-gap) * 1.5) 0 4px 0;
            padding-bottom: 1px;
            font-weight: bold;
        }

        h2 + p {
            margin: var(--margin-top) 0 0 0;
            font-size: var(--font-size);
        }

        .item-gap {
            height: var(--section-gap);
        }

        .item-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-top: var(--margin-top);
        }

        .item-title,
        .item-date {
            font-size: var(--font-size);
        }

        .item-subtitle {
            font-size: var(--font-size);
            margin-top: 1px;
            margin-bottom: 2px;
        }

        ul {
            margin: 2px 0 4px 24px;
            padding-left: 18px;
        }

        li {
            margin-bottom: var(--bullet-gap);
        }

        hr {
            display: none;
        }
    </style>
</head>

<body>
    {{ content }}
</body>

</html>